# Servidor
PORT=3000
HOST=0.0.0.0
# URL pública (HTTPS em produção) — usada nos logs e no OAuth se REDIRECT_URI não estiver definido
PUBLIC_URL=http://localhost:3000

# Anthropic (análise com IA)
ANTHROPIC_API_KEY=

# Google Ads API
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
# URI exata cadastrada no Google Cloud Console:
GOOGLE_ADS_REDIRECT_URI=http://localhost:3000/api/google-ads/callback
# Conta MCC (opcional, só números)
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
# Segredo para assinar cookies de sessão (gere uma string aleatória)
GOOGLE_ADS_SESSION_SECRET=
# Cookies Secure: auto | true | false  (auto = Secure só em HTTPS)
COOKIE_SECURE=auto
